# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=coinkeeper
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key-change-in-production
