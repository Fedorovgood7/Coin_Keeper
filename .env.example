# Yandex OAuth 2.0
# Инструкции по получению ключей:
# 1. Перейдите на https://oauth.yandex.ru/client/new
# 2. Нажмите "Зарегистрировать новое приложение"
# 3. Укажите название: CoinKeeper
# 4. В разделе "Платформы" выберите "Веб-сервисы"
# 5. Укажите Redirect URI: http://localhost:3000/api/v1/auth/yandex/callback
# 6. В разделе "Доступы" выберите:
#    - login:email (получение email)
#    - login:info (получение имени, аватара)
#    - login:avatar (получение аватара)
# 7. Нажмите "Зарегистрировать приложение"
# 8. Скопируйте ID приложения и пароль приложения

YANDEX_CLIENT_ID=your-yandex-client-id
YANDEX_CLIENT_SECRET=your-yandex-client-secret
YANDEX_REDIRECT_URI=http://localhost:3000/api/v1/auth/yandex/callback

# JWT Secret (для продакшена используйте сложный случайный ключ)
# Можно сгенерировать командой: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# JWT Token Duration (в часах)
JWT_TOKEN_DURATION_HOURS=24
